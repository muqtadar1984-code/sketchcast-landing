# SketchCast landing — Pricing page checkout links.
#
# These are PUBLIC Lemon Squeezy hosted-checkout URLs (parents/teachers pay in
# USD) plus the schools enquiry + app sign-up URLs. Not secrets — kept in env so
# they swap between test and live without editing committed code.
#
# Set these in the Cloudflare project's environment variables, then the build
# command `node build-pricing-config.mjs` writes them into pricing.links.js.
# Leave any blank and its CTA degrades gracefully (paid → sign-up, schools →
# mailto). Full checkout URLs (a Lemon Squeezy "buy" link, or a discount-applied
# link for the founding offer), not bare variant IDs.

# Teacher Pro — monthly / annual
LS_TEACHER_PRO_M=
LS_TEACHER_PRO_A=

# Teacher Pro+ — monthly / annual
LS_TEACHER_PROPLUS_M=
LS_TEACHER_PROPLUS_A=

# Parent Family — monthly / annual
LS_PARENT_FAMILY_M=
LS_PARENT_FAMILY_A=

# Founding Teacher — a dedicated variant or discount link that yields $10/mo
LS_FOUNDING_TEACHER=

# Schools — enquiry form URL or a sales@ mailto: (no checkout, no public price)
SCHOOLS_ENQUIRY_URL=

# App sign-up (free CTAs and graceful fallbacks). Has a sensible default.
APP_SIGNUP_URL=https://app.sketchcast.app/signup
